{
  "name": "lobby",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:modellab": "vite --open \"/?debugui=1&sceneui=1&modellab=1\"",
    "build": "vite build && node scripts/syncConfigAliases.mjs",
    "check": "npm run validate:configs && npm run validate:model-assets:strict && npm run test:unit && npm run build && npm run validate:dist && npm run test:e2e:smoke",
    "check:full": "npm run check && npm run test:e2e:modular",
    "promote": "node scripts/promoteConfigOverrides.mjs",
    "ship": "npm run promote && npm run check:full",
    "sync": "npm run sync:shop && npm run sync:projects && npm run sync:videos",
    "sync:ci": "node scripts/syncShopFeed.mjs --defaults-only && node scripts/syncProjectsFeed.mjs --defaults-only && node scripts/syncVideosFeed.mjs --defaults-only",
    "sync:defaults": "npm run sync:shop:defaults && npm run sync:projects:defaults && npm run sync:videos:defaults",
    "validate:configs": "node scripts/validateConfigs.mjs",
    "validate:dist": "node scripts/validateDist.mjs",
    "validate:model-assets": "node scripts/validateModelAssets.mjs",
    "validate:model-assets:strict": "node scripts/validateModelAssets.mjs --strict",
    "inspect:model-intake": "node scripts/inspectExternalModelIntake.mjs",
    "test:unit": "node --test tests/unit/*.test.mjs",
    "preview": "node scripts/serveDist.mjs",
    "test:e2e": "playwright test --config=playwright.config.mjs",
    "test:e2e:modular": "playwright test --config=playwright.config.mjs tests/e2e/modular-showcase.spec.mjs",
    "test:e2e:smoke": "playwright test --config=playwright.config.mjs tests/e2e/lobby-smoke.spec.mjs tests/e2e/model-lab.spec.mjs tests/e2e/webgl-fallback.spec.mjs",
    "test:e2e:headed": "playwright test --config=playwright.config.mjs --headed",
    "sync:shop": "node scripts/syncShopFeed.mjs",
    "sync:shop:defaults": "node scripts/syncShopFeed.mjs --write-defaults --strict",
    "sync:projects": "node scripts/syncProjectsFeed.mjs",
    "sync:projects:defaults": "node scripts/syncProjectsFeed.mjs --write-defaults --strict",
    "sync:videos": "node scripts/syncVideosFeed.mjs",
    "sync:videos:defaults": "node scripts/syncVideosFeed.mjs --write-defaults --strict"
  },
  "dependencies": {
    "three": "^0.181.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "vite": "^7.3.2"
  }
}
